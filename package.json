{
	"name": "roost",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "electron/main.cjs",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"electron": "electron .",
		"electron:dev": "concurrently -k \"vite dev\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
		"electron:build": "npm run build && electron ."
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"electron": "^39.2.7",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"sass": "^1.99.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"wait-on": "^9.0.3"
	},
	"dependencies": {
		"masonry-layout": "^4.2.2"
	}
}
